# Database (local development defaults — change credentials for production)
# Create the role & DB first:
#   sudo -u postgres createuser -P foresthub   # enter password: foresthub
#   sudo -u postgres createdb -O foresthub foresthub
DATABASE_URI=postgresql://foresthub:foresthub@localhost:5432/foresthub

# Payload CMS
PAYLOAD_SECRET=your-secret-here-min-16-chars

# Builder.io
NEXT_PUBLIC_BUILDER_API_KEY=your-builder-api-key

# Site
NEXT_PUBLIC_SITE_URL=https://forestbar.pl
NO_INDEX=true

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=kontakt@forestbar.pl

# Feature flags
NEXT_PUBLIC_ENABLE_3D=true
NEXT_PUBLIC_ENABLE_CUSTOM_CURSOR=true
